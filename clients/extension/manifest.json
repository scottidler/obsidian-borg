{
  "action": {
    "default_icon": {
      "128": "icons/locutus-128.png",
      "16": "icons/locutus-16.png",
      "48": "icons/locutus-48.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "optional": [],
        "required": [
          "none"
        ]
      },
      "id": "obsidian-borg@scottidler",
      "strict_min_version": "140.0"
    }
  },
  "commands": {
    "capture-url": {
      "description": "Capture current tab URL",
      "suggested_key": {
        "default": "Alt+Shift+B"
      }
    }
  },
  "description": "Send the current tab URL to obsidian-borg for ingestion",
  "host_permissions": [
    "http://localhost/*"
  ],
  "icons": {
    "128": "icons/locutus-128.png",
    "16": "icons/locutus-16.png",
    "48": "icons/locutus-48.png"
  },
  "manifest_version": 3,
  "name": "obsidian-borg Capture",
  "options_ui": {
    "open_in_tab": false,
    "page": "options.html"
  },
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "version": "0.2.5"
}
